PORT=3000
CORS_ORIGIN=http://localhost:8081

# Supabase (루트 .env의 EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEY와 값 동일)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# 도서 검색 (카카오 우선, 결과 부족 시 구글 보완)
KAKAO_BOOK_URL=https://dapi.kakao.com/v3/search/book
KAKAO_API_KEY=your-kakao-rest-api-key
GOOGLE_BOOK_URL=https://www.googleapis.com/books/v1/volumes
GOOGLE_BOOK_KEY=your-google-books-api-key
