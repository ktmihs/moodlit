PORT=3000

# Supabase (лЈЁнҠё .envмқҳ EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEYмҷҖ к°’ лҸҷмқј)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
