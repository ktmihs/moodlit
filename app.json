{
  "expo": {
    "name": "mood-lit",
    "slug": "mood-lit",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "scheme": "moodlit",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/c3f6c487-5e41-4fba-8cd8-ba06ef85e094"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ktmihs.moodlit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ktmihs.moodlit"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3f6c487-5e41-4fba-8cd8-ba06ef85e094"
      }
    },
    "owner": "ktmihs"
  }
}
